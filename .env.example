# Copy to a private env file such as ~/.openclaw/skill-forge.env.
# Never commit real tokens.

TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id

# OpenClaw aliases are also supported:
# OPENCLAW_TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
# OPENCLAW_TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id

# Optional: explicit HMAC secret for signed install-approval tokens.
# When unset, the secret is derived deterministically from TELEGRAM_BOT_TOKEN,
# so any environment that can reach the bot can also verify tokens it issued.
# Set this when you want install verification to be independent of the bot
# token (e.g. when verifiers and approvers live in different environments).
# SKILL_FORGE_APPROVAL_SECRET=replace-with-a-long-random-string

