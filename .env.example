# Copy to a private env file such as ~/.openclaw/skill-forge.env.
# Never commit real tokens.

TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id

# OpenClaw aliases are also supported:
# OPENCLAW_TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
# OPENCLAW_TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id

